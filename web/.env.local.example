# Optional: absolute path to the careerbot repo root if the web app is running
# outside it (otherwise the app walks upward looking for SCHEMA.md, which finds
# the repo automatically when web/ is a subdirectory).
# CAREERBOT_DATA_ROOT=/absolute/path/to/careerbot

# Used to auto-fill HQ, industry, and remote policy when you /Add Company in
# the UI. If unset, those fields are left blank for you to fill in by hand.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
